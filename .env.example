# Copy to .env and fill in. If these are absent, the app runs against the
# built-in seed dataset (see src/data/seed.ts) so the dashboard is always demoable.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Active tenant for the current session (demo white-label switcher overrides this).
VITE_DEFAULT_TENANT=northgate
